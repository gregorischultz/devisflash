# ============================================================
# FICHEIRO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE
# Copia este ficheiro para .env e preenche com os teus valores.
# NUNCA envies o ficheiro .env para o Git — ele contém segredos!
# ============================================================

# -----------------------------------------------------------
# BASE DE DADOS
# String de conexão ao MySQL. Formato:
#   mysql://UTILIZADOR:SENHA@HOST:PORTA/NOME_BASE_DE_DADOS
# Se estiveres a desenvolver localmente, instala MySQL e usa:
#   mysql://root:senha@localhost:3306/devisflash
# -----------------------------------------------------------
DATABASE_URL="mysql://utilizador:senha@localhost:3306/devisflash"

# -----------------------------------------------------------
# ANTHROPIC (Claude AI)
# Chave secreta para usar a API do Claude (IA da Anthropic).
# Onde obter: https://console.anthropic.com → API Keys → Create Key
# Usada para: classificar pedidos, estimar urgência, gerar pré-orçamentos
# -----------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."

# -----------------------------------------------------------
# CLOUDFLARE R2 — ARMAZENAMENTO DE FICHEIROS
# O R2 é o serviço de armazenamento de ficheiros da Cloudflare
# (alternativa ao Amazon S3). Usamos para guardar as fotos dos clientes.
#
# Onde configurar: https://dash.cloudflare.com → R2 Object Storage
# -----------------------------------------------------------

# Access Key ID: gerado em R2 → Manage R2 API Tokens → Create API Token
CLOUDFLARE_R2_ACCESS_KEY="sua-access-key-id"

# Secret Access Key: mostrado UMA VEZ ao criar o token. Guarda bem!
CLOUDFLARE_R2_SECRET_KEY="sua-secret-access-key"

# Account ID: visível no canto direito do dashboard da Cloudflare
CLOUDFLARE_R2_ACCOUNT_ID="seu-account-id"

# Nome do bucket onde as fotos serão guardadas (cria em R2 → Create bucket)
CLOUDFLARE_R2_BUCKET_NAME="devisflash-uploads"
