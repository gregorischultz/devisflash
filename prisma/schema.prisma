// Prisma é a ferramenta que usamos para falar com a base de dados.
// Este ficheiro descreve a estrutura de todas as tabelas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Plano {
  BASICO
  PRO
}

enum Urgencia {
  BAIXA
  MEDIA
  ALTA
}

enum StatusPedido {
  PENDENTE    // Chegou, ainda não foi processado pela IA
  PROCESSADO  // A IA já classificou, estimou urgência e gerou orçamento
  CONFIRMADO  // O artisan confirmou o agendamento com o cliente
  CANCELADO   // O trabalho não vai avançar
}

// ─── MODELOS DE AUTENTICAÇÃO (NextAuth) ───────────────────────────────────────
// Estas quatro tabelas são necessárias para o NextAuth funcionar com Prisma.
// Não precisas de as editar manualmente — o NextAuth gere-as automaticamente.

// Utilizador que faz login no sistema (o artisan, não o cliente final)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Senha com hash bcrypt — NUNCA guardamos a senha em texto puro
  password      String?
  accounts      Account[]
  sessions      Session[]
  // Relação 1-para-1 com Tenant: cada utilizador gere um negócio
  tenant        Tenant?

  @@map("users")
}

// Ligação a fornecedores OAuth externos (Google, GitHub, etc.)
// Não usamos no início, mas o NextAuth precisa desta tabela
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Sessões de utilizador (usadas quando a estratégia é "database", não "jwt")
// Incluída para compatibilidade com o adapter do Prisma
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Tokens temporários para verificação de email (magic links)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── MODELOS DE NEGÓCIO ───────────────────────────────────────────────────────

// Tenant = cada artisan que tem uma conta no sistema
model Tenant {
  id          String   @id @default(cuid())
  nome        String
  email       String   @unique
  telefone    String?
  plano       Plano    @default(BASICO)
  corPrimaria String   @default("#2563eb")
  logoUrl     String?
  criadoEm   DateTime @default(now())

  // Relação 1-para-1 com User — o utilizador que faz login neste tenant
  userId   String? @unique
  user     User?   @relation(fields: [userId], references: [id])

  servicos PrecoServico[]
  pedidos  Pedido[]

  @@map("tenants")
}

// Tabela de preços por categoria de serviço, por tenant
model PrecoServico {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  categoria String
  precoMin  Decimal  @db.Decimal(10, 2)
  precoMax  Decimal  @db.Decimal(10, 2)
  criadoEm DateTime @default(now())

  @@map("precos_servico")
}

// Cada pedido de orçamento feito por um cliente final
model Pedido {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  nomeCliente     String
  telefoneCliente String
  descricao       String       @db.Text
  fotoUrl         String?
  // Campos preenchidos pela IA após processamento
  categoria       String?
  urgencia        Urgencia?
  precoMin        Decimal?     @db.Decimal(10, 2)
  precoMax        Decimal?     @db.Decimal(10, 2)
  precoEstimado   Decimal?     @db.Decimal(10, 2)
  status          StatusPedido @default(PENDENTE)
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt

  @@map("pedidos")
}
